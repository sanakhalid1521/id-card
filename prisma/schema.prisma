// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id          Int      @id @default(autoincrement())
  name        String
  rollNo      String   @unique
  className   String   // 'class' is a reserved keyword in some contexts, using className
  section     String
  fatherName  String
  dob         DateTime
  address     String
  phone       String
  photo       String?  // Path to the image in /public/uploads/students/
  issueDate   DateTime @default(now())
  expiryDate  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
